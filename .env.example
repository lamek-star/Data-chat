# Shared cloud project. Safe to expose only the anon/publishable key in the app.
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_PUBLISHABLE_ANON_KEY
VITE_DATACHAT_APP_ID=datachat
VITE_API_BASE_URL=https://datachat.harmongt.uk
VITE_STRIPE_PAYMENT_LINK=https://buy.stripe.com/test_REPLACE_ME
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_ME

# Never put SUPABASE_SERVICE_ROLE_KEY in a Vite/mobile environment variable.

# Stripe values are server-only. Create a recurring Pro Price in Stripe test mode.
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_PRO_PRICE_ID=price_REPLACE_ME
STRIPE_CHECKOUT_MODE=payment
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME
APP_URL=http://localhost:5173
PAYMENTS_PORT=4242
PRO_PLAN_NAME=DataChat Pro
PRO_PLAN_PRICE_LABEL=9.99 USD / month
